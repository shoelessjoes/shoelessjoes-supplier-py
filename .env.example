# --- Supplier site (DealernetX, etc.) ---
# Copy this file to .env and fill in. Never commit .env.
# The YAML config only references these variable NAMES — passwords stay here.
SUPPLIER_USERNAME=
SUPPLIER_PASSWORD=

# --- Shopify (Private app / custom app) ---
# e.g. your-store.myshopify.com
SHOPIFY_SHOP_DOMAIN=
# Admin API access token (needs read_products; read_inventory for UPC tier export)
SHOPIFY_ACCESS_TOKEN=
# e.g. 2024-10 (must match your store/app)
SHOPIFY_API_VERSION=2024-10
